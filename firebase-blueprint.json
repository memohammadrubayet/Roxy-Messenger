{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the messaging application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A chat room (direct message or group).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "participantIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "typing": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "unreadBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "participantIds", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent in a room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "isEncrypted": { "type": "boolean" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string", "enum": ["image", "video", "file"] },
        "fileName": { "type": "string" },
        "readBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reactions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "roomId", "senderId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A personal task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "completed", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores personal tasks."
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Stores chat rooms."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages within a room."
    }
  }
}
